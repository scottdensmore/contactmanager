//
//  Shared, non-personal build settings only. Personal/signing settings — your
//  Apple Developer team, organization identifier, and code-sign identity/style —
//  live in a gitignored DeveloperSettings.xcconfig (pulled in below via
//  `#include?`). Run `./setup.sh` from the repo root to create it. The
//  ORGANIZATION_IDENTIFIER default below keeps a fresh clone / CI building
//  (signing off); your DeveloperSettings.xcconfig overrides it so you get your
//  own bundle id and iCloud container. App version + build live in the Xcode
//  project (auto-bumped by .github/workflows/release.yml).
//
//  Configuration settings file format documentation can be found at:
//  https://help.apple.com/xcode/#/dev745c5c974

ORGANIZATION_IDENTIFIER = com.example

#include? "../DeveloperSettings.xcconfig"
